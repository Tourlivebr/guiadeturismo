---
// Dados dos passeios e receptivo baseados na imagem
const passeiosReceptivo = [
  
  {
    id: 1,
    enabled: false,
    title: "Tour Uva e Vinho + Passeio de Maria Fumaça + Epopeia + Almoço (Coletivo)",
    subtitle: "Com Trem Maria Fumaça e Épopeia",
    category: "PASSEIOS PRIVATIVOS",
    image: "/images/maria-fumaca/fumaca01.jpg",
    rating: 4.93,
    totalRatings: 218,
    price: 550.00,
    installments: "6x sem juros",
    tags: ["Passeio de Trem Maria Fumaça", "Degustação de vinhos e sucos", "Epopeia Italiana"]
  },
  {
    id: 2,
    title: "Translado Hotel - Olivas - Hotel",
    subtitle: "Transporte Executivo com Ar Condicionado",
    category: "TRANSFER",
    image: "/images/olivas_card.jpg",
    rating: 5.0,
    totalRatings: 12,
    price: 160.00,
    installments: "Promoção",
    tags: ["Buscamos e deixamos no hotel", "Carro executivo com ar", "Valor de ida e volta"]
  },
  {
    id: 3,
    title: "Translado Hotel - Skyglass - Hotel",
    subtitle: "Transporte Executivo com Ar Condicionado",
    category: "TRANSFER",
    image: "/images/skyglass.jpg",
    rating: 5.0,
    totalRatings: 8,
    price: 160.00,
    installments: "Promoção",
    tags: ["Buscamos e deixamos no hotel", "Carro executivo com ar", "Valor de ida e volta"]
  },
  {
    id: 4,
    title: "Transfer para Vinícola Jolimont + Salamaria Chaulet + Igreja de Pedra",
    subtitle: "Transporte Executivo com Ar Condicionado",
    category: "TRANSFER",
    image: "/images/jolimont.jpg",
    rating: 5.0,
    totalRatings: 0,
    price: 150.00,
    installments: "Ingresso à parte",
    tags: ["Vinícola Jolimont (ingresso à parte)", "Salamaria Chaulet", "Igreja de Pedra em Canela"]
  },
  {
    id: 5,
    title: "Transfer Ida e Volta (POA ou Caxias/ Gramado ou Canela)",
    subtitle: "Transporte Privativo",
    category: "RECEPTIVO",
    image: "/images/Transfer/Transfer.jpg",
    rating: 4.95,
    totalRatings: 127,
    price: 700.00,
    installments: "6x sem juros",
    tags: ["Sem espera no embarque/desembarque", "Embarque imediato", "Privacidade total"]
  },
  {
    id: 6,
    title: "City Tour Privativo em Gramado e Canela (9h)",
    subtitle: "Roteiro flexível com motorista/guia • Busca no hotel",
    category: "CITY TOUR",
    image: "/images/dreams/dreamland-museu-de-cera-gramado-rs-1.jpg",
    rating: 5.0,
    totalRatings: 0,
    price: null,
    installments: "Sob consulta",
    tags: [
      "Lago Negro, Mini Mundo, Cristais de Gramado e centro de Canela",
      "Bondinhos Aéreos / Parque da Serra e Castelinho do Caracol",
      "Inclui veículo privativo com motorista/guia",
      "Não inclui almoço, bebidas e ingressos"
    ]
  },
];
---

<section id="passeios-receptivo" class="relative pb-12 lg:pb-20 pt-0 bg-gradient-to-br from-gray-50 to-blue-50 dark:from-gray-900 dark:to-blue-900">
  <div class="container mx-auto px-4">
    <!-- Header da Seção -->
    <div class="text-center">
      <div class="flex items-center justify-center mb-6">
        <div class="h-px bg-gradient-to-r from-transparent via-primary-400 to-transparent flex-1 max-w-xs"></div>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mx-8">
          Translados e <span class="text-primary-600 dark:text-primary-400">Passeios</span>
        </h2>
        <div class="h-px bg-gradient-to-r from-transparent via-primary-400 to-transparent flex-1 max-w-xs"></div>
      </div>
    </div>

    <!-- Carrossel Container -->
    <div class="relative z-20">
      <!-- Carrossel -->
      <div class="overflow-hidden">
        <div id="carousel-track-passeios-receptivo" class="flex transition-transform duration-500 ease-in-out">
          {passeiosReceptivo.filter((passeio) => passeio.enabled !== false).map((passeio) => (
            <div class="flex-none w-full sm:w-1/2 lg:w-1/3 xl:w-1/4 px-3">
              <!-- Card -->
              <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden group h-full flex flex-col">
                <!-- Imagem -->
              <div class="relative h-44 overflow-hidden">
                  <img 
                    src={passeio.image} 
                    alt={passeio.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute top-3 left-3">
                    <span class="bg-primary-600 text-white px-2 py-1 rounded-full text-xs font-semibold">
                      {passeio.category}
                    </span>
                  </div>
                </div>

                <!-- Conteúdo -->
                <div class="p-4 flex-1 flex flex-col">
                  <!-- Título e Subtítulo -->
                  <div class="mb-2">
                    <h3 class="font-bold text-gray-900 dark:text-white text-lg mb-1 group-hover:text-primary-600 transition-colors">
                      {passeio.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                      {passeio.subtitle}
                    </p>
                  </div>

                  <!-- Preço e Botão -->
                  <div class="mt-2 lg:mt-auto pt-3 border-t border-gray-100 dark:border-gray-700">
                    <div class="flex items-center justify-between mb-3">
                      <div>
                        <p class="text-xs text-gray-500 dark:text-gray-400">A partir de</p>
                        <p class="text-xl font-bold text-primary-600">
                          {passeio.price === null ? 'Sob consulta' : `R$ ${passeio.price.toFixed(2).replace('.', ',')}`}
                        </p>
                      </div>
                    </div>
                    
                    {passeio.id === 6 ? (
                      <button
                        type="button"
                        data-open-passeio-details="1"
                        data-title={passeio.title}
                        data-subtitle={passeio.subtitle}
                        data-details={JSON.stringify(passeio.tags ?? [])}
                        data-href="#contato"
                        class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-6 rounded-lg transition-colors flex items-center justify-center space-x-2 text-sm"
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
                        </svg>
                        <span>RESERVE AGORA</span>
                      </button>
                    ) : (
                      <a 
                        href={passeio.id === 2 ? '/translados' :
                              passeio.id === 3 ? '/translado-skyglass' :
                              passeio.id === 4 ? '/translados' :
                              passeio.id === 5 ? '/transfer-privativo' :
                              '#'}
                        class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-6 rounded-lg transition-colors flex items-center justify-center space-x-2 text-sm"
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd" />
                        </svg>
                        <span>RESERVE AGORA</span>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Botões de Navegação -->
      <button 
        id="prev-btn-passeios-receptivo"
        class="hidden sm:block absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-white dark:bg-gray-800 shadow-lg rounded-full p-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors z-10"
        aria-label="Anterior"
      >
        <svg class="w-6 h-6 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      
      <button 
        id="next-btn-passeios-receptivo"
        class="hidden sm:block absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-white dark:bg-gray-800 shadow-lg rounded-full p-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors z-10"
        aria-label="Próximo"
      >
        <svg class="w-6 h-6 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Indicadores -->
    <div id="indicators-passeios-receptivo" class="flex justify-center mt-4 pb-4 gap-2 relative z-20">
      <!-- Indicadores serão gerados dinamicamente pelo JavaScript -->
    </div>
  </div>

  <div id="passeios-receptivo-modal" class="fixed inset-0 z-50 hidden">
    <div data-close-passeios-receptivo-modal="1" class="absolute inset-0 bg-black/50"></div>
    <div class="relative mx-auto mt-16 w-[calc(100%-2rem)] max-w-lg bg-white dark:bg-gray-900 rounded-2xl shadow-2xl overflow-hidden">
      <div class="p-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 id="passeios-receptivo-modal-title" class="text-lg font-bold text-gray-900 dark:text-white"></h3>
            <p id="passeios-receptivo-modal-subtitle" class="text-sm text-gray-600 dark:text-gray-400 mt-1"></p>
          </div>
          <button type="button" data-close-passeios-receptivo-modal="1" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300">
            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>

        <ul id="passeios-receptivo-modal-details" class="mt-4 space-y-2 text-sm text-gray-700 dark:text-gray-200"></ul>

        <a id="passeios-receptivo-modal-action" href="https://wa.me/5554993220552" target="_blank" rel="noopener noreferrer" class="mt-5 w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded-lg transition-colors flex items-center justify-center text-sm">
          IR PARA CONTATO
        </a>
      </div>
    </div>
  </div>

  <!-- Divisor Boleado Suave -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0] z-10">
    <svg 
      viewBox="0 0 1200 120" 
      preserveAspectRatio="none" 
      class="relative block w-[calc(100%+1.3px)] h-[40px] lg:h-[60px]"
    >
      <path d="M0,0 C300,120 900,120 1200,0 L1200,120 L0,120 Z" class="fill-white dark:fill-gray-900"></path>
    </svg>
  </div>
</section>

<script>
  function initCarouselPasseiosReceptivo() {
    let currentSlide = 0;
    const carouselTrack = document.getElementById('carousel-track-passeios-receptivo');
    const prevBtn = document.getElementById('prev-btn-passeios-receptivo');
    const nextBtn = document.getElementById('next-btn-passeios-receptivo');
    const indicatorsContainer = document.getElementById('indicators-passeios-receptivo');

    if (!carouselTrack || !indicatorsContainer) return;

    const visibleItems = [...carouselTrack.children];

    function getSlidesPerView() {
      const width = window.innerWidth;
      if (width >= 1280) return 4;
      if (width >= 1024) return 3;
      if (width >= 640) return 2;
      return 1;
    }
    
    function getTotalSlides() {
      const slidesPerView = getSlidesPerView();
      return Math.max(1, Math.ceil(visibleItems.length - slidesPerView + 1));
    }

    function updateIndicators() {
      const totalSlides = getTotalSlides();
      indicatorsContainer.innerHTML = '';
      
      for (let i = 0; i < totalSlides; i++) {
        const indicator = document.createElement('button');
        indicator.className = `w-3 h-3 rounded-full transition-colors ${
          i === currentSlide ? 'bg-primary-600' : 'bg-gray-300 dark:bg-gray-600'
        }`;
        indicator.addEventListener('click', () => {
          currentSlide = i;
          updateCarousel();
        });
        indicatorsContainer.appendChild(indicator);
      }
    }
    
    function updateCarousel() {
      const firstItem = carouselTrack.children[0];
      const itemWidth = firstItem ? firstItem.getBoundingClientRect().width : 0;
      carouselTrack.style.transform = `translateX(-${currentSlide * itemWidth}px)`;
      updateIndicators();
    }

    function nextSlide() {
      const totalSlides = getTotalSlides();
      currentSlide = (currentSlide + 1) % totalSlides;
      updateCarousel();
    }
    
    function prevSlide() {
      const totalSlides = getTotalSlides();
      currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
      updateCarousel();
    }

    nextBtn?.addEventListener('click', nextSlide);
    prevBtn?.addEventListener('click', prevSlide);

    let startX = 0;
    let isDragging = false;

    carouselTrack.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
    }, { passive: true });
    
    carouselTrack.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      
      const endX = e.changedTouches[0].clientX;
      const diffX = startX - endX;
      
      if (Math.abs(diffX) > 50) {
        if (diffX > 0) {
          nextSlide();
        } else {
          prevSlide();
        }
      }
      
      isDragging = false;
    }, { passive: true });

    let autoPlayInterval;
    function startAutoPlay() {
      autoPlayInterval = setInterval(nextSlide, 5000);
    }
    
    function stopAutoPlay() {
      clearInterval(autoPlayInterval);
    }

    carouselTrack.addEventListener('mouseenter', stopAutoPlay);
    carouselTrack.addEventListener('mouseleave', startAutoPlay);
    carouselTrack.addEventListener('touchstart', stopAutoPlay, { passive: true });
    carouselTrack.addEventListener('touchend', () => {
      setTimeout(startAutoPlay, 3000);
    }, { passive: true });

    window.addEventListener('resize', () => {
      currentSlide = 0;
      updateCarousel();
    });

    updateCarousel();
    startAutoPlay();

    const modal = document.getElementById('passeios-receptivo-modal');
    if (modal && modal.dataset.bound !== '1') {
      modal.dataset.bound = '1';
      const modalTitle = document.getElementById('passeios-receptivo-modal-title');
      const modalSubtitle = document.getElementById('passeios-receptivo-modal-subtitle');
      const modalDetails = document.getElementById('passeios-receptivo-modal-details');
      const modalAction = document.getElementById('passeios-receptivo-modal-action');

      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }

      function openModal(payload) {
        if (modalTitle) modalTitle.textContent = payload.title || '';
        if (modalSubtitle) modalSubtitle.textContent = payload.subtitle || '';
        if (modalDetails) {
          modalDetails.innerHTML = '';
          const items = Array.isArray(payload.details) ? payload.details : [];
          items.forEach((text) => {
            const li = document.createElement('li');
            li.className = 'flex gap-2';
            li.innerHTML = `<span class="mt-1 h-2 w-2 rounded-full bg-primary-600 flex-none"></span><span class="leading-5">${String(text)}</span>`;
            modalDetails.appendChild(li);
          });
        }
        if (modalAction) {
          const phone = '5554993220552';
          const title = payload.title ? String(payload.title) : '';
          const text = title ? `Olá! Quero reservar: ${title}` : 'Olá! Quero reservar um passeio.';
          modalAction.setAttribute('href', `https://wa.me/${phone}?text=${encodeURIComponent(text)}`);
        }

        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      document.addEventListener('click', (e) => {
        const openBtn = e.target?.closest?.('[data-open-passeio-details="1"]');
        if (openBtn) {
          e.preventDefault();
          let details = [];
          try {
            details = JSON.parse(openBtn.getAttribute('data-details') || '[]');
          } catch {}
          openModal({
            title: openBtn.getAttribute('data-title') || '',
            subtitle: openBtn.getAttribute('data-subtitle') || '',
            details
          });
          return;
        }

        const closeTarget = e.target?.closest?.('[data-close-passeios-receptivo-modal="1"]');
        if (closeTarget) {
          e.preventDefault();
          closeModal();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeModal();
        }
      });

      modalAction?.addEventListener('click', () => {
        closeModal();
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarouselPasseiosReceptivo);
  } else {
    initCarouselPasseiosReceptivo();
  }
</script>
