---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StarRating from '../components/StarRating.astro';

// Dados dos passeios (categoria "PASSEIOS PRIVATIVOS" e "RECEPTIVO")
const passeios = [
  {
    id: 1,
    titulo: "Transfer Ida e Volta (POA ou Caxias/ Gramado ou Canela)",
    subtitulo: "Transporte Privativo",
    categoria: "RECEPTIVO",
    imagem: "/images/Transfer/Transfer.jpg",
    avaliacao: 4.95,
    totalAvaliacoes: 127,
    preco: 700.00,
    slug: "transfer-privativo",
    duracao: "4-5 horas",
    tags: ["Sem espera no embarque/desembarque", "Embarque imediato", "Privacidade total"]
  },
  {
    id: 2,
    titulo: "Tour Uva e Vinho + Passeio de Maria Fumaça + Epopeia + Almoço (Coletivo)",
    subtitulo: "Com Trem Maria Fumaça e Épopeia",
    categoria: "PASSEIOS PRIVATIVOS",
    imagem: "/images/maria-fumaca/fumaca01.jpg",
    avaliacao: 4.93,
    totalAvaliacoes: 218,
    preco: 550.00,
    slug: "tour-trem-vinho-maria-fumaca",
    duracao: "8 horas",
    tags: ["Passeio de Trem Maria Fumaça", "Degustação de vinhos e sucos", "Epopeia Italiana"]
  },
  {
    id: 3,
    titulo: "Ensaio Fotográfico Gramado e Canela",
    subtitulo: "Passeio Privativo",
    categoria: "PASSEIOS PRIVATIVOS",
    imagem: "/images/ensaios-fotograficos/ensaios.jpeg",
    avaliacao: 4.95,
    totalAvaliacoes: 38,
    preco: 490.00,
    slug: "ensaio-fotografico-gramado-canela",
    duracao: "3-4 horas",
    tags: ["Com charme e romantismo", "Que a cidade oferece", "Preparamos o passeio fotográfico 'Gramado e Canela VIP'"]
  },
  {
    id: 4,
    titulo: "Translado Hotel - Olivas - Hotel",
    subtitulo: "Transporte Executivo com Ar Condicionado",
    categoria: "RECEPTIVO",
    imagem: "/images/Transfer/Transfer.jpg",
    avaliacao: 5.0,
    totalAvaliacoes: 12,
    preco: 160.00,
    slug: "translados",
    duracao: "Flexível",
    tags: ["Buscamos e deixamos no hotel", "Carro executivo com ar", "Valor de ida e volta"]
  },
  {
    id: 5,
    titulo: "Translado Hotel - Skyglass - Hotel",
    subtitulo: "Transporte Executivo com Ar Condicionado",
    categoria: "RECEPTIVO",
    imagem: "/images/Transfer/Transfer.jpg",
    avaliacao: 5.0,
    totalAvaliacoes: 8,
    preco: 160.00,
    slug: "translado-skyglass",
    duracao: "Flexível",
    tags: ["Buscamos e deixamos no hotel", "Carro executivo com ar", "Valor de ida e volta"]
  }
];
---

<BaseLayout 
  title="Passeios - Guia Turismo Serra Gaúcha"
  description="Descubra os melhores passeios privativos e receptivo em Gramado e Canela. Experiências únicas na Serra Gaúcha."
>
  <Header />
  
  <main class="pt-20 lg:pt-24">
<!-- Hero Section -->
<section 
  class="relative text-white py-8 lg:py-20 bg-fixed bg-center bg-cover"
  style="background-image: url('/images/link_passeios1.jpg'); filter: brightness(1.05) contrast(1.1) saturate(1.2);"
>
  <!-- Overlay branco bem leve só pra não perder legibilidade -->
  <div class="absolute inset-0 bg-white/10"></div>

  <div class="relative container mx-auto px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl lg:text-7xl font-bold mb-6 leading-tight">Translados e Passeios</h1>
      <p class="text-xl lg:text-2xl text-green-100 mb-8 leading-relaxed">
        Experiências autênticas e inesquecíveis na região colonial
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <div class="flex items-center text-green-100">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          Guia especializado
        </div>
        <div class="flex items-center text-green-100">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          Transporte incluso
        </div>
        <div class="flex items-center text-green-100">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          Experiência personalizada
        </div>
      </div>
    </div>
  </div>

  <!-- Divisor Boleado Suave -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0] z-20">
    <svg 
      viewBox="0 0 1200 120" 
      preserveAspectRatio="none" 
      class="relative block w-[calc(100%+1.3px)] h-[30px] lg:h-[50px]"
    >
      <path d="M0,0 C300,120 900,120 1200,0 L1200,120 L0,120 Z" class="fill-gray-50 dark:fill-gray-900"></path>
    </svg>
  </div>
</section>


    <!-- Filtros -->
    <section class="py-6 bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800">
      <div class="container mx-auto px-4">
      </div>
    </section>

    <!-- Grid de Passeios -->
    <section class="py-20 bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800">
      <div class="container mx-auto px-4">
        <div id="passeios-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {passeios.map((passeio) => (
            <div class="passeio-card group bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 border border-gray-100 dark:border-gray-700" data-category={passeio.categoria.toLowerCase().replace(' ', '-').replace('passeios-privativos', 'privativos')}>
              <div class="relative overflow-hidden">
                <img 
                  src={passeio.imagem} 
                  alt={passeio.titulo}
                  class="w-full h-56 object-cover transition-transform duration-500 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute top-4 left-4">
                  <span class="bg-green-600 text-white px-4 py-2 rounded-full text-xs font-bold shadow-lg backdrop-blur-sm">
                    {passeio.categoria}
                  </span>
                </div>
                <div class="absolute top-4 right-4">
                  <div class="bg-white/90 backdrop-blur-sm rounded-full p-2 shadow-lg">
                    <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                </div>
              </div>
              
              <div class="p-6 h-full flex flex-col">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3 line-clamp-2 group-hover:text-green-600 transition-colors duration-300">
                  {passeio.titulo}
                </h3>
                <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm">
                  {passeio.subtitulo}
                </p>
                
                <div class="border-t border-gray-100 dark:border-gray-700 pt-6 mt-auto">
                  <div class="flex items-center justify-between mb-6">
                    <div>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">A partir de</p>
                      <p class="text-3xl font-bold text-green-600 dark:text-green-400">
                        R$ {passeio.preco.toFixed(2).replace('.', ',')}
                      </p>
                    </div>
                  </div>
                  <a 
                    href={`/${passeio.slug}`}
                    class="w-full bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 block text-center shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
                  >
                    <span class="flex items-center justify-center gap-2">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path>
                      </svg>
                      RESERVE AGORA
                    </span>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Filtros
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active de todos os botões
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-green-600', 'text-white');
        b.classList.add('bg-gray-200', 'text-gray-700', 'dark:bg-gray-700', 'dark:text-gray-300');
      });
      
      // Adiciona active ao botão clicado
      btn.classList.remove('bg-gray-200', 'text-gray-700', 'dark:bg-gray-700', 'dark:text-gray-300');
      btn.classList.add('bg-green-600', 'text-white');
      
      const filter = btn.dataset.filter;
      const cards = document.querySelectorAll('.passeio-card');
      
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>